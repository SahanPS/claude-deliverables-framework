# The private overlay — real firm assets, rate cards, client conventions.
# This is the whole point of the split: never let this reach a public remote.
private/*
!private/README.md
*-private/

# API keys / secrets — never commit these (e.g. FAL_KEY for solution-diagrams' fal.ai integration)
.env
.env.*

# OS / editor noise
.DS_Store
*.swp

# Build artefacts
node_modules/
*.log
dist/
*.zip

# Rendered diagram output (generated by scripts/render-mermaid.sh)
*.svg.png
